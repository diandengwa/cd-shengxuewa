# OPC 内容工厂环境变量配置
# 复制此文件为 .env 并填写实际值
# 注意: .env 文件不应提交到Git仓库

# === 基础路径 ===
# Windows示例: D:\\opc
# Linux示例: /opt/opc
OPC_ROOT=D:\\opc

# === API密钥 (必填) ===
# DeepSeek API Key
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# mptext API Key (用于采集)
MPTEXT_API_KEY=your_mptext_api_key_here

# GitHub Token (用于同步)
GITHUB_TOKEN=ghp_your_github_token_here

# === 数据库配置 (可选) ===
# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=opc
POSTGRES_USER=opc
POSTGRES_PASSWORD=your_postgres_password_here

# Redis (用于缓存和队列)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# === 微信推送配置 (可选) ===
# 服务器端禁用微信推送，保留在Windows本地执行
WECHAT_ENABLED=false
WECHAT_CDP_URL=http://localhost:9222

# === 日志配置 (可选) ===
LOG_LEVEL=INFO
LOG_FORMAT=json
