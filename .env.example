# K12 Rocket v2.0 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# 注意: .env 文件不应提交到Git仓库

# === 基础配置 ===
K12_ENV=development   # development | production
K12_HOST=127.0.0.1
K12_PORT=8000
K12_LOG_LEVEL=info     # debug | info | warning | error
PYTHONIOENCODING=utf-8

# === 知识库路径 ===
KNOWLEDGE_BASE_DIR=D:\\opc-agent-knowledge

# === 管理员密码 (必填，未设置将拒绝启动) ===
K12_ADMIN_SECRET=your_admin_secret_here

# === DeepSeek LLM 密钥 (必填) ===
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# === 微信服务号基本参数 ===
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret
WECHAT_TOKEN=your_wechat_token

# === 微信商户支付 V3 参数 ===
WECHAT_MCH_ID=your_mch_id
WECHAT_PAY_SERIAL_NO=your_serial_no
WECHAT_PAY_API_KEY=your_32_byte_api_v3_key_here__
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/pay/wechat/notify
WECHAT_PAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_content_here\n-----END PRIVATE KEY-----"

# === CORS 配置 (生产环境必填) ===
K12_CORS_ORIGINS=https://your-domain.com

# === GitHub Token (用于同步) ===
GITHUB_TOKEN=ghp_your_github_token_here

# === 日志配置 ===
LOG_LEVEL=INFO
